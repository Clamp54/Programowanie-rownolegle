void bubblesort(int *v, int n) {
for (int i = 0; i < n - 1; i++) {
for (int j = 0; j < n - i - 1; j++) {
if (v[j] > v[j + 1]) {
swap(v[j], v[j + 1]);
}
}
}
}
int *merge(int *v1, int n1, int v2, int n2) {
int *result = new int[n1 + n2];
int i = 0, j = 0, k = 0;
while (i < n1 && j < n2) {
if (v1[i] < v2[j]) result[k++] = v1[i++];
else result[k++] = v2[j++];
}
while (i < n1) result[k++] = v1[i++];
while (j < n2) result[k++] = v2[j++];
return result;
}
