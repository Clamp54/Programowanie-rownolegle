#include <iostream>
#include <mpi.h>
#include <vector>
#include <algorithm>
#include <ctime>
using namespace std;
void bubblesort(int *v, int n) {
for (int i = 0; i < n - 1; i++) {
for (int j = 0; j < n - i - 1; j++) {
if (v[j] > v[j + 1]) {
swap(v[j], v[j + 1]);
}
}
}
}
int *merge(int *v1, int n1, int v2, int n2) {
int *result = new int[n1 + n2];
int i = 0, j = 0, k = 0;
while (i < n1 && j < n2) {
if (v1[i] < v2[j]) result[k++] = v1[i++];
else result[k++] = v2[j++];
}
while (i < n1) result[k++] = v1[i++];
while (j < n2) result[k++] = v2[j++];
return result;
}
int main(int argc, char **argv) {
MPI_Init(&argc, &argv);
int rank, size;
MPI_Comm_rank(MPI_COMM_WORLD, &rank);
MPI_Comm_size(MPI_COMM_WORLD, &size);
int n = 123; 
int *data = NULL;
int chunk_size = (n + size - 1) / size;
int padded_n = chunk_size * size;
if (rank == 0) {
data = new int[padded_n];
srand(time(NULL));
for (int i = 0; i < padded_n; i++) {
if (i < n) data[i] = rand() % 1001;
else data[i] = 0;
}
cout << "Tablica przed: ";
for (int i = 0; i < n; i++) cout << data[i] << " ";
cout << endl;
}
MPI_Barrier(MPI_COMM_WORLD);
double t1 = MPI_Wtime();
MPI_Bcast(&n, 1, MPI_INT, 0, MPI_COMM_WORLD);
int *chunk = new int[chunk_size];
MPI_Scatter(data, chunk_size, MPI_INT, chunk, chunk_size, MPI_INT, 0, MPI_COMM_WORLD);
if (rank == 0) {
delete[] data;
data = NULL;
}
int s = (rank == size - 1) ? (n - rank * chunk_size) : chunk_size;
if (s < 0) s = 0;
bubblesort(chunk, s);
int step = 1;
while (step < size) {
if (rank % (2 * step) != 0) {
int dest = rank - step;
MPI_Send(&s, 1, MPI_INT, dest, 0, MPI_COMM_WORLD);
MPI_Send(chunk, s, MPI_INT, dest, 0, MPI_COMM_WORLD);
break;
}
if (rank + step < size) {
int src = rank + step;
int s_recv;
MPI_Recv(&s_recv, 1, MPI_INT, src, 0, MPI_COMM_WORLD, MPI_STATUS_IGNORE);
int *received = new int[s_recv];
MPI_Recv(received, s_recv, MPI_INT, src, 0, MPI_COMM_WORLD, MPI_STATUS_IGNORE);
int *temp_merged = merge(chunk, s, received, s_recv);
delete[] chunk;
delete[] received;
chunk = temp_merged;
s += s_recv;
}
step *= 2;
}
double t2 = MPI_Wtime();
if (rank == 0) {
cout << "Tablica po: ";
for (int i = 0; i < s; i++) cout << chunk[i] << " ";
cout << endl;
cout << "Czas: " << t2 - t1 << "s | Procesy: " << size << endl;
delete[] chunk;
}
MPI_Finalize();
return 0;
}
